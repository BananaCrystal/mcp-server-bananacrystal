{
  "name": "@bananacrystal/mcp-server",
  "version": "1.0.0",
  "description": "MCP server for BananaCrystal - enables AI agents to interact with BananaCrystal's payment infrastructure",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "bananacrystal-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "mock": "tsx mock/server.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bananacrystal",
    "hedera",
    "payments",
    "crypto",
    "ai",
    "claude",
    "agent"
  ],
  "author": "BananaCrystal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BananaCrystal/mcp-server-bananacrystal.git"
  },
  "bugs": {
    "url": "https://github.com/BananaCrystal/mcp-server-bananacrystal/issues"
  },
  "homepage": "https://github.com/BananaCrystal/mcp-server-bananacrystal#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^12.0.0",
    "chalk": "^4.1.2",
    "inquirer": "^8.2.6",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/inquirer": "^8.2.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "QUICKSTART.md"
  ]
}
